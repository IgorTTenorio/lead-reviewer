APP_NAME=lead-reviewer
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/lead_reviewer
ALEMBIC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/lead_reviewer
AI_PROVIDER=mock
AI_MODEL=keyword-heuristic-v1
AI_BASE_URL=
AI_API_KEY=
AI_TIMEOUT_SECONDS=30
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
